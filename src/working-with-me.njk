{% block pageStyles %}
<style>
  /* HERO */
  .s-hero { background: rgb(255,255,255); padding-top: 4rem; padding-bottom: 3rem; }
  .s-hero h1 { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.6rem, 4.5vw, 3.8rem); font-weight: 400; font-style: italic; line-height: 1.15; color: #1a1a1a; margin-bottom: 1.5rem; }
  .s-hero h1 span.orange { color: #E8601C; }
  .s-hero p { font-size: 1.05rem; line-height: 1.85; color: #444444; }

  /* PHOTOGRAPHY */
  .s-photo { background: rgb(255,255,255); padding-bottom: 0; }
  .photo-crop { width: 100%; height: 420px; overflow: hidden; }
  .photo-crop img { width: 100%; height: 100%; object-fit: cover; object-position: center top; display: block; }

  /* TIMELINE — orange */
  .s-timeline { background: #E8601C; padding-top: 3.5rem; padding-bottom: 3.5rem; }
  .timeline-wrap { position: relative; }
  .timeline-track { position: relative; height: 2px; background: rgba(255,255,255,0.2); }
  .timeline-fill { position: absolute; left: 0; top: 0; height: 100%; width: 100%; background: rgba(255,255,255,0.4); }
  .timeline-nodes { display: flex; justify-content: space-between; margin-top: -9px; }
  .t-node { display: flex; flex-direction: column; align-items: center; flex: 1; }
  .t-dot { width: 16px; height: 16px; border-radius: 50%; background: rgb(255,255,255); border: 2px solid #E8601C; outline: 1.5px solid rgba(255,255,255,0.5); flex-shrink: 0; margin-bottom: 0.6rem; }
  .t-label { font-family: 'DM Sans', sans-serif; font-size: 0.75rem; color: rgba(255,255,255,0.85); text-align: center; max-width: 68px; line-height: 1.4; }

  /* STAGES SHARED */
  .stage-section { padding-top: 3.5rem; padding-bottom: 3.5rem; }
  .stage-grid { display: grid; grid-template-columns: 260px 1fr; gap: 0; align-items: start; }
  .stage-left { padding-right: 3rem; border-right: 0.5px solid #e8e8e8; }
  .stage-left-blue { padding-right: 3rem; border-right: 0.5px solid #c8d8f0; }
  .stage-right { padding-left: 3rem; }
  .stage-num { font-family: 'DM Sans', sans-serif; font-size: 0.7rem; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: #23418e; margin-bottom: 0.5rem; }
  .stage-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(1.4rem, 2.2vw, 1.8rem); font-style: italic; font-weight: 400; color: #E8601C; line-height: 1.3; margin-bottom: 1.5rem; }
  .milestone { display: flex; align-items: flex-start; gap: 0.6rem; margin-bottom: 0.6rem; }
  .m-dot { width: 8px; height: 8px; border-radius: 50%; background: #E8601C; flex-shrink: 0; margin-top: 0.45rem; }
  .m-label { font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 300; color: #444444; line-height: 1.5; }

  /* KEY STATEMENT */
  .key-statement { font-family: 'Cormorant Garamond', serif; font-size: clamp(1.6rem, 2.5vw, 2.1rem); font-style: italic; font-weight: 400; color: #1a1a1a; line-height: 1.4; margin-bottom: 1.5rem; }

  /* DETAIL CARDS */
  .detail-card { border: 0.5px solid #e8e8e8; padding: 1.1rem 1.25rem; margin-bottom: 0.75rem; background: rgb(255,255,255); }
  .detail-card:last-child { margin-bottom: 0; }
  .card-tag { font-family: 'DM Sans', sans-serif; font-size: 0.7rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: #E8601C; margin-bottom: 0.4rem; }
  .card-body { font-family: 'DM Sans', sans-serif; font-size: 0.95rem; font-weight: 300; line-height: 1.75; color: #444444; }

  /* STAGE BACKGROUNDS */
  .s-stage-one { background: rgb(255,255,255); }
  .s-stage-two { background: #f2f8ff; }
  .s-stage-three { background: rgb(255,255,255); }

  /* CTA */
  .s-cta { background: #f2f8ff; border-top: 0.5px solid #ddeaf8; padding-top: 3.5rem; padding-bottom: 4.5rem; }
  .cta-h2 { font-family: 'Cormorant Garamond', serif; font-size: clamp(1.8rem, 2.8vw, 2.4rem); font-weight: 400; font-style: normal; line-height: 1.3; color: #1a1a1a; margin-bottom: 1.75rem; max-width: 620px; }

  @media (max-width: 900px) {
    .photo-crop { height: 260px; }
    .stage-grid { grid-template-columns: 1fr; }
    .stage-left, .stage-left-blue { padding-right: 0; border-right: none; border-bottom: 0.5px solid #e8e8e8; padding-bottom: 1.5rem; margin-bottom: 1.5rem; }
    .stage-right { padding-left: 0; }
    /* Timeline: vertical on mobile */
    .timeline-track { display: none; }
    .timeline-nodes { flex-direction: column; margin-top: 0; gap: 0; position: relative; }
    .timeline-nodes::before { content: ''; position: absolute; left: 7px; top: 8px; bottom: 8px; width: 2px; background: rgba(255,255,255,0.4); }
    .t-node { flex-direction: row; align-items: flex-start; gap: 0.75rem; padding: 0.5rem 0; flex: none; }
    .t-dot { margin-bottom: 0; margin-top: 0.1rem; flex-shrink: 0; position: relative; z-index: 1; }
    .t-label { text-align: left; max-width: none; }
  }
</style>
{% endblock %}

